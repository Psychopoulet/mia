{

  "name": "mia",
  "version": "1.0.1",
  "description": "MIA - easy IOT.",

  "type": "commonjs",
  "typings": "./lib/cjs/main.d.cts",
  "main": "./lib/cjs/main.cjs",

  "exports": {
    ".": {
      "require": {
        "types": "./lib/cjs/main.d.cts",
        "default": "./lib/cjs/main.cjs"
      }
    }
  },

  "scripts": {

    "prepare": "npx husky || true",

    "lint-back": "npx eslint --config .eslintrc-back.js --ext .ts,.cts,.mts ./lib/src/**/*",
    "lint-front": "echo 'Frontend lint not implemented yet.'",
    "lint-tests": "echo 'Tests not implemented yet.'",
    "lint": "npm run lint-back && npm run lint-front && npm run lint-tests",

    "clean-back": "npx rimraf ./lib/cjs",
    "clean-front": "npx rimraf ./public/cjs",
    "clean": "npm run clean-back && npm run clean-front",

    "build-back": "npm run clean-back && npx tsc --project ./tsconfig.json",
    "build-front": "echo 'Frontend build not implemented yet.'",
    "build": "npm run build-back && npm run build-front",

    "check-requires": "npx used-deps-analyzer \"./package.json\" \"./lib/src\" --no-dev --shadows @fortawesome/fontawesome-free --misscalled \"{ \\\"module\\\": \\\"@fortawesome/fontawesome-free\\\", \\\"call\\\": \\\"@fortawesome\\\" }\"",
    "check-updates": "npx check-version-modules --no-fail-at-major --fail-at-minor --fail-at-patch",
    "unit-tests": "echo 'Tests not implemented yet.'",

    "tests": "npm run-script lint && npm run-script check-requires && npm run-script check-updates && npm run-script unit-tests",

    "start": "node lib/cjs/main.cjs",

    "daemon-start": "npx pm2 start pm2.json",
    "daemon-restart": "npx pm2 reload pm2.json",
    "daemon-stop": "npx pm2 stop pm2.json && npx pm2 delete pm2.json",

    "docker-build": "docker image build --rm -t image-mia .",
    "docker-run": "docker container run -dti --name container-mia -p 8000:8000 image-mia",
    "docker-stop": "docker container stop container-mia && docker container remove -f container-mia",
    "docker-remove": "docker image remove -f image-mia"

  },

  "files": [
    "lib/cjs",
    "public/dist",
    "pm2.json"
  ],
  "engines": {
    "node": ">=22.22.0"
  },

  "dependencies": {
    "@fortawesome/fontawesome-free": "7.2.0",
    "bootstrap": "5.3.8",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "node-confmanager": "1.10.0",
    "node-containerpattern": "1.9.0",
    "node-pluginsmanager": "3.1.0",
    "winston": "3.19.0",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.5.2",
    "@types/socket.io": "3.0.2",
    "@types/ws": "8.18.1",
    "check-version-modules": "2.2.2",
    "coveralls": "3.1.1",
    "eslint-plugin-personnallinter": "git+ssh://git@github.com/Psychopoulet/eslint-plugin-personnallinter",
    "husky": "9.1.7",
    "mocha": "11.7.5",
    "node-pluginsmanager-plugin": "7.0.1",
    "nyc": "18.0.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "used-deps-analyzer": "0.2.0"
  },
  "optionalDependencies": {
    "pm2": "6.0.14"
  },

  "husky": {
    "hooks": {
      "pre-commit": "npm run lint",
      "pre-push": "npm run unit-tests"
    }
  },
  "author": "Sébastien VIDAL",
  "contributors": [],
  "license": "ISC",

  "homepage": "https://github.com/Psychopoulet/mia#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/Psychopoulet/mia.git"
  },
  "bugs": {
    "url": "https://github.com/Psychopoulet/mia/issues"
  }

}
