		"/public/bundle.min.js.map": {
			"get": {
				"description": "",
				"summary": "Front app map",
				"responses": {
					"200": {
						"description": "Everything is fine",
						"content": {
							"text/javascript": {
								"schema": {
									"type": "string"
								}
