									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/public/bundle.min.js": {
			"get": {
				"description": "",
				"summary": "Front app",
				"responses": {
					"200": {
						"description": "Everything is fine",
						"content": {
							"text/javascript": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
