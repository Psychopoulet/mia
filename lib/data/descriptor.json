		"schemas": {
			"Error": {
				"type": "object",
				"properties": {
					"code": {
						"type": "string"
					},
					"message": {
						"type": "string"
					}
				},
				"required": [ "code", "message" ]
			}
		}
	},
	"externalDocs": {
		"description": "Find out more about this API",
