								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/public/index.html": {
			"get": {
				"description": "",
				"summary": "Front page",
				"responses": {
					"200": {
						"description": "Everything is fine",
						"content": {
							"text/html": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
